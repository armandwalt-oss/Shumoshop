@model WebApplication1.Models.ShippingSettings

@{
    ViewData["Title"] = "Shipping Settings";
}

<div class="container py-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h3 mb-1">Shipping Settings</h1>
            <p class="text-muted mb-0">
                Control how shipping is calculated at checkout. Settings apply to every order
                placed after you save.
            </p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fa-solid fa-arrow-left"></i> Back to Admin
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    <form asp-action="ShippingSettings" method="post" class="card shadow-sm">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />

        <div class="card-body">
            <div class="form-check form-switch mb-4">
                <input asp-for="UseLiveTcgRates" class="form-check-input" type="checkbox" role="switch" />
                <label asp-for="UseLiveTcgRates" class="form-check-label fw-semibold"></label>
                <div class="form-text">
                    When on, ShumoShop asks The Courier Guy for a live rate at checkout and adds
                    your markup. When off, every order under the free-shipping threshold gets
                    charged the flat Door-to-Door rate below. Either way, orders at or above the
                    threshold ship free.
                </div>
            </div>

            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="DoorToDoorRate" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text">R</span>
                        <input asp-for="DoorToDoorRate" class="form-control" type="number" step="0.01" min="0" />
                    </div>
                    <span asp-validation-for="DoorToDoorRate" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="DoorToLockerRate" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text">R</span>
                        <input asp-for="DoorToLockerRate" class="form-control" type="number" step="0.01" min="0" />
                    </div>
                    <span asp-validation-for="DoorToLockerRate" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="DoorToKioskRate" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text">R</span>
                        <input asp-for="DoorToKioskRate" class="form-control" type="number" step="0.01" min="0" />
                    </div>
                    <span asp-validation-for="DoorToKioskRate" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="FreeShippingThreshold" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text">R</span>
                        <input asp-for="FreeShippingThreshold" class="form-control" type="number" step="0.01" min="0" />
                    </div>
                    <div class="form-text">Subtotal at or above this value ships free.</div>
                    <span asp-validation-for="FreeShippingThreshold" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="MarkupRand" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text">R</span>
                        <input asp-for="MarkupRand" class="form-control" type="number" step="0.01" min="0" />
                    </div>
                    <div class="form-text">Added on top of the live TCG rate (live mode only).</div>
                    <span asp-validation-for="MarkupRand" class="text-danger small"></span>
                </div>

                <hr class="my-3" />

                <div class="col-md-6">
                    <label asp-for="LowStockThreshold" class="form-label">
                        <i class="fa-solid fa-triangle-exclamation"></i>
                        Low-stock threshold
                    </label>
                    <input asp-for="LowStockThreshold" class="form-control" type="number" min="0" step="1" />
                    <div class="form-text">
                        Products with stock at or below this number show up on the
                        <a asp-action="LowStock">Low Stock</a> report and as an alert on the dashboard.
                    </div>
                    <span asp-validation-for="LowStockThreshold" class="text-danger small"></span>
                </div>
            </div>

            @if (Model.UpdatedAt != default)
            {
                <hr class="my-4" />
                <p class="text-muted small mb-0">
                    Last updated @Model.UpdatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                    @if (!string.IsNullOrEmpty(Model.UpdatedByUserId))
                    {
                        <text> by user @Model.UpdatedByUserId</text>
                    }
                </p>
            }
        </div>

        <div class="card-footer text-end">
            <button type="submit" class="btn btn-primary">
                <i class="fa-solid fa-save"></i> Save Settings
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
