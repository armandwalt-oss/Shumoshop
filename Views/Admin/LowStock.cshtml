@model List<WebApplication1.Models.Product>
@{
    ViewData["Title"] = "Low Stock";
    var threshold = (int)(ViewBag.Threshold ?? 10);
}

<link href="~/css/admin.css" rel="stylesheet" />

<div class="container py-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h3 mb-1">
                <i class="fa-solid fa-triangle-exclamation text-warning"></i>
                Low Stock Report
            </h1>
            <p class="text-muted mb-0">
                Products with stock at or below the configured threshold
                (currently <strong>@threshold</strong>).
                <a asp-action="ShippingSettings">Change threshold</a>
            </p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fa-solid fa-arrow-left"></i> Back to Admin
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-success">
            <i class="fa-solid fa-check-circle"></i>
            Everything is above the threshold — nothing to worry about right now.
        </div>
    }
    else
    {
        <div class="alert alert-warning d-flex align-items-center">
            <i class="fa-solid fa-triangle-exclamation me-2"></i>
            <div>
                <strong>@Model.Count</strong> product@(Model.Count == 1 ? "" : "s") at or below threshold.
                Restock soon to avoid going out of stock.
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>SKU</th>
                            <th>Name</th>
                            <th>Category</th>
                            <th class="text-end">Stock</th>
                            <th class="text-end">Price</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model)
                        {
                            var rowClass = p.StockQuantity == 0 ? "table-danger"
                                         : p.StockQuantity <= threshold / 2 ? "table-warning"
                                         : "";
                            <tr class="@rowClass">
                                <td><code>@p.SKU</code></td>
                                <td>
                                    <div class="fw-semibold">@p.Name</div>
                                </td>
                                <td>
                                    @p.Category?.Name
                                    @if (p.SubCategory != null)
                                    {
                                        <span class="text-muted">— @p.SubCategory.Name</span>
                                    }
                                </td>
                                <td class="text-end">
                                    @if (p.StockQuantity == 0)
                                    {
                                        <span class="badge bg-danger">Out of stock</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">@p.StockQuantity</span>
                                    }
                                </td>
                                <td class="text-end">R @p.Price.ToString("N2")</td>
                                <td class="text-end">
                                    <a asp-controller="DevChanges" asp-action="ProductDetails" asp-route-id="@p.Id"
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="fa-solid fa-pen-to-square"></i> Edit
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
