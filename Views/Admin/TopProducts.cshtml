@model List<WebApplication1.Services.TopProductRow>
@{
    ViewData["Title"] = "Top Viewed Products";
    int daysBack   = ViewBag.DaysBack   ?? 7;
    int topN       = ViewBag.TopN       ?? 50;
    int totalViews = ViewBag.TotalViews ?? 0;
}

<link href="~/css/admin.css" rel="stylesheet" />

<div class="container py-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h3 mb-1">
                <i class="fa-solid fa-chart-line"></i>
                Top Viewed Products
            </h1>
            <p class="text-muted mb-0">
                Product detail page hits over the last <strong>@daysBack</strong> days.
                Total: <strong>@totalViews.ToString("N0")</strong> view(s).
            </p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fa-solid fa-arrow-left"></i> Back to Admin
        </a>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-body py-2 d-flex flex-wrap align-items-center gap-2">
            <span class="text-muted me-2">Window:</span>
            @foreach (var d in new[] { 1, 7, 30, 90 })
            {
                if (d == daysBack)
                {
                    <span class="btn btn-sm btn-primary">@d day@(d == 1 ? "" : "s")</span>
                }
                else
                {
                    <a asp-action="TopProducts" asp-route-daysBack="@d" asp-route-topN="@topN"
                       class="btn btn-sm btn-outline-secondary">@d day@(d == 1 ? "" : "s")</a>
                }
            }
            <span class="text-muted ms-3 me-2">Show:</span>
            @foreach (var n in new[] { 10, 25, 50, 100 })
            {
                if (n == topN)
                {
                    <span class="btn btn-sm btn-primary">Top @n</span>
                }
                else
                {
                    <a asp-action="TopProducts" asp-route-daysBack="@daysBack" asp-route-topN="@n"
                       class="btn btn-sm btn-outline-secondary">Top @n</a>
                }
            }
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            No product views recorded in the selected window. Browse a product
            on the shop side to generate some data.
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 60px;">Rank</th>
                            <th>Product</th>
                            <th>SKU</th>
                            <th class="text-end">Views</th>
                            <th class="text-end" style="width: 140px;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int rank = 0; var max = Model.First().ViewCount; }
                        @foreach (var row in Model)
                        {
                            rank++;
                            var pct = max == 0 ? 0 : (int)Math.Round(100.0 * row.ViewCount / max);
                            <tr>
                                <td><strong>#@rank</strong></td>
                                <td>@row.Name</td>
                                <td><code>@row.SKU</code></td>
                                <td class="text-end">
                                    <div class="d-flex align-items-center justify-content-end gap-2">
                                        <div class="progress" style="height: 6px; width: 120px;">
                                            <div class="progress-bar bg-primary" style="width:@(pct)%;"></div>
                                        </div>
                                        <strong>@row.ViewCount</strong>
                                    </div>
                                </td>
                                <td class="text-end">
                                    <a asp-controller="DevChanges" asp-action="ProductDetails" asp-route-id="@row.ProductId"
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="fa-solid fa-pen-to-square"></i> Edit
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
