@model IEnumerable<WebApplication1.Models.Store>

@{
    ViewData["Title"] = "Find a Store";
}

<link href="~/css/findastore.css" rel="stylesheet" />

<div class="store-page">
    <div class="store-container">
        <div class="store-header">
            <h1>Find a Store Near You</h1>
            <p>Visit us at one of our convenient locations</p>
        </div>

        @if (Model != null && Model.Any())
        {
            @foreach (var store in Model)
            {
                <div class="store-detail-card">
                    <div class="store-title-section">
                        <h2>Get In Touch.</h2>
                        <h1 class="store-name">@store.Name</h1>
                    </div>

                    <div class="store-info-grid">
                        <div class="info-column">
                            <div class="info-item">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                                    <circle cx="12" cy="10" r="3"></circle>
                                </svg>
                                <div>
                                    <h3>Store Location</h3>
                                    <p>@store.Address</p>
                                    @if (!string.IsNullOrEmpty(store.City))
                                    {
                                        <p>@store.City, @store.State, @store.ZipCode</p>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="info-column">
                            <div class="info-item">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                                </svg>
                                <div>
                                    <h3>Phone</h3>
                                    @if (!string.IsNullOrEmpty(store.Phone))
                                    {
                                        <p><a href="tel:@store.Phone">@store.Phone</a></p>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="info-column">
                            <div class="info-item">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                                    <polyline points="22,6 12,13 2,6"></polyline>
                                </svg>
                                <div>
                                    <h3>Email us</h3>
                                    @if (!string.IsNullOrEmpty(store.Email))
                                    {
                                        <p><strong>Sales:</strong> <a href="mailto:@store.Email">@store.Email</a></p>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(store.Hours))
                    {
                        <div class="trading-hours-section">
                            <h2>Trading Hours</h2>
                            <div class="hours-display">
                                <p>@store.Hours</p>
                            </div>
                        </div>
                    }

                    <div class="map-section">
                        <iframe src="https://www.google.com/maps?q=@Uri.EscapeDataString(store.Address + ", " + store.City + ", " + store.State)&output=embed"
                                width="100%"
                                height="400"
                                style="border:0; border-radius: 10px;"
                                allowfullscreen=""
                                loading="lazy"
                                referrerpolicy="no-referrer-when-downgrade">
                        </iframe>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="no-stores">
                <p>No stores available at the moment. Please check back later.</p>
            </div>
        }
    </div>
</div>