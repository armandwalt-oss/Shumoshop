@{
    ViewData["Title"] = "Payment Failed";
    var order = ViewBag.Order as WebApplication1.Models.Order;
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-danger">
                <div class="card-body text-center py-5">
                    <!-- Failed Icon -->
                    <div class="mb-4">
                        <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" fill="currentColor" class="bi bi-x-circle-fill text-danger" viewBox="0 0 16 16">
                            <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zM5.354 4.646a.5.5 0 1 0-.708.708L7.293 8l-2.647 2.646a.5.5 0 0 0 .708.708L8 8.707l2.646 2.647a.5.5 0 0 0 .708-.708L8.707 8l2.647-2.646a.5.5 0 0 0-.708-.708L8 7.293 5.354 4.646z" />
                        </svg>
                    </div>

                    <h2 class="text-danger mb-3">Payment Failed</h2>
                    <p class="lead mb-4">@ViewBag.Message</p>

                    @if (order != null)
                    {
                        <div class="bg-light p-4 rounded mb-4">
                            <h5 class="mb-3">Order Information</h5>
                            <div class="row">
                                <div class="col-md-6 text-start">
                                    <p class="mb-2"><strong>Order Number:</strong></p>
                                    <p class="mb-2"><strong>Total Amount:</strong></p>
                                </div>
                                <div class="col-md-6 text-start">
                                    <p class="mb-2">@order.OrderNumber</p>
                                    <p class="mb-2"><strong>R @order.TotalAmount.ToString("N2")</strong></p>
                                </div>
                            </div>
                        </div>

                        <div class="alert alert-warning" role="alert">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            Your order has been saved but payment was not completed.
                        </div>
                    }

                    <!-- Reasons for Failure -->
                    <div class="text-start mb-4">
                        <h6>Common reasons for payment failure:</h6>
                        <ul class="text-muted">
                            <li>Insufficient funds</li>
                            <li>Incorrect card details</li>
                            <li>Card declined by bank</li>
                            <li>3D Secure authentication failed</li>
                        </ul>
                    </div>

                    <!-- Action Buttons -->
                    <div class="d-grid gap-2 d-md-flex justify-content-md-center mt-4">
                        @if (order != null)
                        {
                            <a href="@Url.Action("Process", "Payment", new { orderId = order.Id })"
                               class="btn btn-primary btn-lg px-5">
                                Try Payment Again
                            </a>
                        }
                        <a href="@Url.Action("Index", "Cart")" class="btn btn-outline-secondary btn-lg px-5">
                            Back to Cart
                        </a>
                    </div>

                    <p class="text-muted mt-4 small">
                        Need help? <a href="@Url.Action("Index", "ContactUs")">Contact our support team</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>