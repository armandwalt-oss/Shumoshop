@{
    ViewData["Title"] = "Payment Processing";
    var order = ViewBag.Order as WebApplication1.Models.Order;
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-warning">
                <div class="card-body text-center py-5">
                    <!-- Pending Icon with Animation -->
                    <div class="mb-4">
                        <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" fill="currentColor" class="bi bi-hourglass-split text-warning" viewBox="0 0 16 16">
                            <path d="M2.5 15a.5.5 0 1 1 0-1h1v-1a4.5 4.5 0 0 1 2.557-4.06c.29-.139.443-.377.443-.59v-.7c0-.213-.154-.451-.443-.59A4.5 4.5 0 0 1 3.5 3V2h-1a.5.5 0 0 1 0-1h11a.5.5 0 0 1 0 1h-1v1a4.5 4.5 0 0 1-2.557 4.06c-.29.139-.443.377-.443.59v.7c0 .213.154.451.443.59A4.5 4.5 0 0 1 12.5 13v1h1a.5.5 0 0 1 0 1h-11zm2-13v1c0 .537.12 1.045.337 1.5h6.326c.216-.455.337-.963.337-1.5V2h-7zm3 6.35c0 .701-.478 1.236-1.011 1.492A3.5 3.5 0 0 0 4.5 13s.866-1.299 3-1.48V8.35zm1 0v3.17c2.134.181 3 1.48 3 1.48a3.5 3.5 0 0 0-1.989-3.158C8.978 9.586 8.5 9.052 8.5 8.351z" />
                        </svg>
                    </div>

                    <h2 class="text-warning mb-3">Payment Processing</h2>
                    <p class="lead mb-4">@ViewBag.Message</p>

                    @if (order != null)
                    {
                        <div class="bg-light p-4 rounded mb-4">
                            <h5 class="mb-3">Order Information</h5>
                            <div class="row">
                                <div class="col-md-6 text-start">
                                    <p class="mb-2"><strong>Order Number:</strong></p>
                                    <p class="mb-2"><strong>Total Amount:</strong></p>
                                    <p class="mb-2"><strong>Payment Status:</strong></p>
                                </div>
                                <div class="col-md-6 text-start">
                                    <p class="mb-2">@order.OrderNumber</p>
                                    <p class="mb-2"><strong>R @order.TotalAmount.ToString("N2")</strong></p>
                                    <p class="mb-2"><span class="badge bg-warning text-dark">@order.PaymentStatus</span></p>
                                </div>
                            </div>
                        </div>

                        <div class="alert alert-info" role="alert">
                            <i class="bi bi-info-circle me-2"></i>
                            We're waiting for payment confirmation from PayFast. This usually takes a few seconds.
                        </div>
                    }

                    <!-- What Happens Next -->
                    <div class="text-start mb-4">
                        <h6>What happens next?</h6>
                        <ul class="text-muted">
                            <li>You'll receive an email confirmation once payment is verified</li>
                            <li>Your order will be visible in "My Orders"</li>
                            <li>Processing typically completes within 1-2 minutes</li>
                        </ul>
                    </div>

                    <!-- Action Buttons -->
                    <div class="d-grid gap-2 d-md-flex justify-content-md-center mt-4">
                        <a href="@Url.Action("Orders", "Account")" class="btn btn-primary btn-lg px-5">
                            View My Orders
                        </a>
                        <a href="@Url.Action("Index", "Shop")" class="btn btn-outline-secondary btn-lg px-5">
                            Continue Shopping
                        </a>
                    </div>

                    <!-- Refresh Suggestion -->
                    <div class="mt-4">
                        <button onclick="location.reload()" class="btn btn-sm btn-link">
                            <i class="bi bi-arrow-clockwise me-1"></i>Refresh Page
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Simple pulse animation for hourglass */
    .bi-hourglass-split {
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
    }
</style>