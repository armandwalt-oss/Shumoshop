@model WebApplication1.Models.Order

@{
    ViewData["Title"] = "Order Confirmation";
}

<link href="~/css/orderconfirmation.css" rel="stylesheet" />

<div class="confirmation-container">
    <!-- Success Header -->
    <div class="success-header">
        <div class="success-icon">
            <i class="fa-solid fa-circle-check"></i>
        </div>
        <h1>Order Confirmed!</h1>
        <p>Thank you for your order. We've received your order and will process it shortly.</p>
    </div>

    <!-- Order Details Card -->
    <div class="order-details-card">
        <div class="order-header">
            <div>
                <h2>Order #@Model.OrderNumber</h2>
                <p class="order-date">Placed on @Model.OrderDate.ToString("MMMM dd, yyyy 'at' hh:mm tt")</p>
            </div>
            <div class="status-badge @Model.Status.ToLower()">
                @Model.Status
            </div>
        </div>

        <div class="info-grid">
            <div class="info-section">
                <h3><i class="fa-solid fa-user"></i> Customer Information</h3>
                <p><strong>Name:</strong> @Model.CustomerName</p>
                <p><strong>Email:</strong> @Model.Email</p>
                <p><strong>Phone:</strong> @Model.PhoneNumber</p>
            </div>

            <div class="info-section">
                <h3><i class="fa-solid fa-truck"></i> Shipping Address</h3>
                <p>@Model.ShippingAddress</p>
                <p>@Model.ShippingCity, @Model.ShippingState</p>
                <p>@Model.ShippingPostalCode</p>
            </div>

            <div class="info-section">
                <h3><i class="fa-solid fa-calendar-days"></i> Delivery Information</h3>
                @if (Model.EstimatedDelivery.HasValue)
                {
                    <p><strong>Estimated Delivery:</strong></p>
                    <p class="highlight">@Model.EstimatedDelivery.Value.ToString("MMMM dd, yyyy")</p>
                }
                else
                {
                    <p>Delivery date will be confirmed via email</p>
                }
            </div>

            <div class="info-section">
                <h3><i class="fa-solid fa-credit-card"></i> Payment Status</h3>
                <p><strong>Method:</strong> @Model.PaymentMethod</p>
                <p class="payment-pending">
                    <i class="fa-solid fa-clock"></i>
                    Payment instructions will be sent to your email
                </p>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.CustomerComments))
        {
            <div class="order-notes">
                <h3><i class="fa-solid fa-note-sticky"></i> Order Notes</h3>
                <p>@Model.CustomerComments</p>
            </div>
        }
    </div>

    <!-- Order Items -->
    <div class="order-items-card">
        <h2><i class="fa-solid fa-box"></i> Order Items</h2>

        <div class="items-list">
            @foreach (var item in Model.OrderItems)
            {
                <div class="order-item">
                    <div class="item-image">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" alt="@item.ProductName" />
                        }
                        else
                        {
                            <div class="placeholder-icon">
                                <i class="fa-solid fa-image"></i>
                            </div>
                        }
                    </div>
                    <div class="item-details">
                        <h4>@item.ProductName</h4>
                        <p class="item-sku">SKU: @item.ProductSKU</p>
                        <p class="item-quantity">Quantity: @item.Quantity</p>
                    </div>
                    <div class="item-pricing">
                        <p class="unit-price">R @item.UnitPrice.ToString("N2") each</p>
                        <p class="total-price">R @item.TotalPrice.ToString("N2")</p>
                    </div>
                </div>
            }
        </div>

        <!-- Order Summary -->
        <div class="order-summary">
            <div class="summary-row">
                <span>Subtotal:</span>
                <span>R @Model.Subtotal.ToString("N2")</span>
            </div>
            <div class="summary-row">
                <span>Shipping:</span>
                <span>
                    @if (Model.ShippingCost == 0)
                    {
                        <span class="free-text">FREE</span>
                    }
                    else
                    {
                        <span>R @Model.ShippingCost.ToString("N2")</span>
                    }
                </span>
            </div>
            <div class="summary-row">
                <span>Tax (VAT 15%):</span>
                <span>R @Model.Tax.ToString("N2")</span>
            </div>
            <div class="summary-divider"></div>
            <div class="summary-row summary-total">
                <span>Total:</span>
                <span>R @Model.TotalAmount.ToString("N2")</span>
            </div>
        </div>
    </div>

    <!-- What's Next Section -->
    <div class="next-steps-card">
        <h2><i class="fa-solid fa-list-check"></i> What Happens Next?</h2>
        <div class="steps-grid">
            <div class="step">
                <div class="step-number">1</div>
                <h4>Order Confirmation</h4>
                <p>You'll receive an email confirmation with your order details and payment instructions.</p>
            </div>
            <div class="step">
                <div class="step-number">2</div>
                <h4>Payment Processing</h4>
                <p>Follow the payment instructions in your email to complete your order.</p>
            </div>
            <div class="step">
                <div class="step-number">3</div>
                <h4>Order Processing</h4>
                <p>Once payment is confirmed, we'll prepare your order for shipment.</p>
            </div>
            <div class="step">
                <div class="step-number">4</div>
                <h4>Delivery</h4>
                <p>Your order will be shipped and you'll receive tracking information via email.</p>
            </div>
        </div>
    </div>

    <!-- Action Buttons -->
    <div class="action-buttons">
        <a asp-controller="Order" asp-action="MyOrders" class="btn-primary">
            <i class="fa-solid fa-list"></i> View My Orders
        </a>
        <a asp-controller="Shop" asp-action="Index" class="btn-secondary">
            <i class="fa-solid fa-shopping-bag"></i> Continue Shopping
        </a>
        <a asp-controller="Home" asp-action="Index" class="btn-tertiary">
            <i class="fa-solid fa-home"></i> Go to Homepage
        </a>
    </div>

    <!-- Help Section -->
    <div class="help-section">
        <p>
            <i class="fa-solid fa-circle-question"></i>
            Need help with your order? <a asp-controller="ContactUs" asp-action="Index">Contact our support team</a>
        </p>
    </div>
</div>
