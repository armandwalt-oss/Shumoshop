@model List<WebApplication1.Models.Address>

@{
    ViewData["Title"] = "My Addresses";
}

<link href="~/css/account.css" rel="stylesheet" />

<div class="account-container">
    <!-- Breadcrumb -->
    <div class="breadcrumb">
        <a asp-controller="Account" asp-action="Index">My Account</a>
        <span>/</span>
        <span>Addresses</span>
    </div>

    <!-- Page Header -->
    <div class="page-header">
        <div>
            <h1><i class="fa-solid fa-location-dot"></i> My Addresses</h1>
            <p>Manage your shipping and billing addresses</p>
        </div>
        <a asp-controller="Account" asp-action="AddAddress" class="btn-add-address">
            <i class="fa-solid fa-plus"></i>
            Add New Address
        </a>
    </div>

    <!-- Addresses Grid -->
    @if (Model != null && Model.Any())
    {
        <div class="addresses-grid">
            @foreach (var address in Model)
            {
                <div class="address-card @(address.IsDefaultShipping || address.IsDefaultBilling ? "default-address" : "")">
                    <!-- Address Header -->
                    <div class="address-card-header">
                        <div class="address-label">
                            @if (!string.IsNullOrEmpty(address.Label))
                            {
                                <i class="fa-solid fa-tag"></i>
                                <span>@address.Label</span>
                            }
                            else
                            {
                                <i class="fa-solid fa-location-dot"></i>
                                <span>@address.AddressType Address</span>
                            }
                        </div>

                        <!-- Default Badges -->
                        <div class="address-badges">
                            @if (address.IsDefaultShipping)
                            {
                                <span class="badge-default-shipping">
                                    <i class="fa-solid fa-truck"></i> Default Shipping
                                </span>
                            }
                            @if (address.IsDefaultBilling)
                            {
                                <span class="badge-default-billing">
                                    <i class="fa-solid fa-file-invoice"></i> Default Billing
                                </span>
                            }
                        </div>
                    </div>

                    <!-- Address Content -->
                    <div class="address-card-body">
                        <div class="address-info">
                            <p class="address-name">
                                <i class="fa-solid fa-user"></i>
                                <strong>@address.FullName</strong>
                            </p>
                            <p class="address-street">
                                <i class="fa-solid fa-location-dot"></i>
                                @address.StreetAddress
                                @if (!string.IsNullOrEmpty(address.ApartmentUnit))
                                {
                                    <text>, @address.ApartmentUnit</text>
                                }
                            </p>
                            <p class="address-city">
                                @address.City, @address.State @address.PostalCode
                            </p>
                            <p class="address-country">
                                @address.Country
                            </p>
                            <p class="address-phone">
                                <i class="fa-solid fa-phone"></i>
                                @address.PhoneNumber
                            </p>

                            @if (!string.IsNullOrEmpty(address.DeliveryInstructions))
                            {
                                <p class="delivery-instructions">
                                    <i class="fa-solid fa-note-sticky"></i>
                                    <em>@address.DeliveryInstructions</em>
                                </p>
                            }
                        </div>
                    </div>

                    <!-- Address Actions -->
                    <div class="address-card-footer">
                        <a asp-controller="Account" asp-action="EditAddress" asp-route-id="@address.Id" class="btn-edit-address">
                            <i class="fa-solid fa-pen"></i>
                            Edit
                        </a>

                        @if (!address.IsDefaultShipping && !address.IsDefaultBilling)
                        {
                            <form asp-controller="Account" asp-action="DeleteAddress" method="post" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this address?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@address.Id" />
                                <button type="submit" class="btn-delete-address">
                                    <i class="fa-solid fa-trash"></i>
                                    Delete
                                </button>
                            </form>
                        }
                        else
                        {
                            <span class="cannot-delete-notice">
                                <i class="fa-solid fa-info-circle"></i>
                                Cannot delete default address
                            </span>
                        }
                    </div>
                </div>
            }
        </div>

        <!-- Address Tips -->
        <div class="address-tips">
            <h3><i class="fa-solid fa-lightbulb"></i> Tips</h3>
            <ul>
                <li>Set a default shipping address for faster checkout</li>
                <li>You can have different billing and shipping addresses</li>
                <li>Add delivery instructions to help with deliveries</li>
                <li>Default addresses cannot be deleted - change default first</li>
            </ul>
        </div>
    }
    else
    {
        <div class="empty-state-large">
            <i class="fa-solid fa-location-dot"></i>
            <h2>No Addresses Saved</h2>
            <p>Add an address to make checkout faster and easier!</p>
            <a asp-controller="Account" asp-action="AddAddress" class="btn-add-first-address">
                <i class="fa-solid fa-plus"></i>
                Add Your First Address
            </a>
        </div>
    }
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="success-notification">
        <i class="fa-solid fa-check-circle"></i>
        @TempData["SuccessMessage"]
    </div>
}
