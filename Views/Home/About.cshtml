@{
    ViewData["Title"] = "About Us";
}

<link href="~/css/about.css" rel="stylesheet" />

<!-- About Hero Section -->
<section class="about-hero">
    <div class="container">
        <h1>About ShumoShop.com™</h1>
        <p class="hero-tagline">Shop Smart, Save More!</p>
    </div>
</section>

<!-- Who We Are -->
<section class="about-section">
    <div class="container">
        <div class="section-content">
            <h2>Who We Are</h2>
            <p>
                Welcome to <strong>ShumoShop.com™</strong> – Your smart, reliable online shopping destination built around one simple idea:
                Great products, great prices, and a shopping experience you can trust.
            </p>
            <p>
                We are a proudly customer-focused online store dedicated to bringing you a wide variety of quality products,
                carefully selected to meet everyday needs. From practical essentials to exciting finds, our mission is to make
                shopping easy, affordable, and enjoyable for everyone.
            </p>
        </div>
    </div>
</section>

<!-- Our Story -->
<section class="about-section gray-bg">
    <div class="container">
        <div class="section-content">
            <h2>Our Story</h2>
            <p>
                ShumoShop.com™ was created with a vision to offer more than just another online store.
                We wanted to build a platform where customers feel confident, valued, and excited to shop.
            </p>
            <p>We understand that modern shoppers want:</p>

            <div class="features-grid">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fa-solid fa-certificate"></i>
                    </div>
                    <h3>Quality they can rely on</h3>
                    <p>Every product is carefully selected and tested</p>
                </div>

                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fa-solid fa-tag"></i>
                    </div>
                    <h3>Prices that make sense</h3>
                    <p>Fair pricing with no hidden fees</p>
                </div>

                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fa-solid fa-truck-fast"></i>
                    </div>
                    <h3>Fast, friendly service</h3>
                    <p>Quick delivery and responsive support</p>
                </div>

                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fa-solid fa-shield-halved"></i>
                    </div>
                    <h3>A secure and simple checkout</h3>
                    <p>Safe payments and easy ordering</p>
                </div>
            </div>

            <p class="highlight-text">That's exactly what we deliver.</p>
        </div>
    </div>
</section>

<!-- Core Values -->
<section class="about-section">
    <div class="container">
        <div class="section-content">
            <h2>What We Stand For</h2>
            <p class="intro-text">At ShumoShop.com™, we live by three core values:</p>

            <div class="values-grid">
                <div class="value-card">
                    <div class="value-icon">
                        <i class="fa-solid fa-lightbulb"></i>
                    </div>
                    <h3>Smart Shopping</h3>
                    <p>We carefully source products that offer real value – not just low prices, but the right balance of quality and affordability.</p>
                </div>

                <div class="value-card">
                    <div class="value-icon">
                        <i class="fa-solid fa-users"></i>
                    </div>
                    <h3>Customer First</h3>
                    <p>Your satisfaction is our priority. From browsing to delivery, we aim to give you a smooth and stress-free experience.</p>
                </div>

                <div class="value-card">
                    <div class="value-icon">
                        <i class="fa-solid fa-arrow-trend-up"></i>
                    </div>
                    <h3>Continuous Improvement</h3>
                    <p>We're always expanding our range, improving our service, and finding new ways to help you save more.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Why Choose Us -->
<section class="about-section gray-bg">
    <div class="container">
        <div class="section-content">
            <h2>Why Choose Us?</h2>
            <div class="benefits-grid">
                <div class="benefit-item">
                    <i class="fa-solid fa-check-circle"></i>
                    <span>Wide range of products</span>
                </div>
                <div class="benefit-item">
                    <i class="fa-solid fa-check-circle"></i>
                    <span>Secure online payments</span>
                </div>
                <div class="benefit-item">
                    <i class="fa-solid fa-check-circle"></i>
                    <span>Reliable delivery</span>
                </div>
                <div class="benefit-item">
                    <i class="fa-solid fa-check-circle"></i>
                    <span>Friendly customer support</span>
                </div>
                <div class="benefit-item">
                    <i class="fa-solid fa-check-circle"></i>
                    <span>Honest pricing with no surprises</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Our Promise -->
<section class="about-section">
    <div class="container">
        <div class="section-content">
            <h2>Our Promise to You</h2>
            <p>
                When you shop with ShumoShop.com™, you're not just another order number. You're part of our growing community.
                We promise to:
            </p>
            <ul class="promise-list">
                <li>Treat every customer with respect</li>
                <li>Offer products we believe in</li>
                <li>Provide clear communication</li>
                <li>Always strive to do better</li>
            </ul>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="cta-section">
    <div class="container">
        <h2>Ready to Start Shopping?</h2>
        <p>Join thousands of happy customers who shop smart and save more!</p>
        <a asp-controller="Shop" asp-action="Index" class="btn-cta">Start Shopping Now</a>
    </div>
</section>
