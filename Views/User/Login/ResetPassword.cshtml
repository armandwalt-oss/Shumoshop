@model WebApplication1.Controllers.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
}

<link href="~/css/login.css" rel="stylesheet" />

<div class="login-page">
    <div class="login-container">
        <div class="login-card">
            <h1>Reset Your Password</h1>
            <p class="subtitle">Choose a new password for your account.</p>

            <form asp-action="ResetPassword" method="post" class="login-form">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="All" class="text-danger validation-summary"></div>

                <input asp-for="Email" type="hidden" />
                <input asp-for="Token" type="hidden" />

                <div class="form-group">
                    <label asp-for="NewPassword">New password</label>
                    <input asp-for="NewPassword" type="password" class="form-control" autocomplete="new-password" required />
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ConfirmPassword">Confirm new password</label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control" autocomplete="new-password" required />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <button type="submit" class="btn-login">Update password</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
