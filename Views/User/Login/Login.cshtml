@model WebApplication1.Models.LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<link href="~/css/login.css" rel="stylesheet" />

<div class="login-page">
    <div class="login-container">
        <div class="login-header">
            <h1>Welcome Back</h1>
            <p>Sign in to your account to continue</p>
        </div>

        <div class="login-card">
            <form asp-controller="Login" asp-action="Login" method="post" class="login-form">

                <div asp-validation-summary="ModelOnly" class="error-summary"></div>

                <div class="form-group">
                    <label asp-for="Email"></label>
                    <input asp-for="Email" class="form-control" placeholder="Enter your email" autocomplete="username" />
                    <span asp-validation-for="Email" class="error-message"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Password"></label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="Enter your password" autocomplete="current-password" />
                    <span asp-validation-for="Password" class="error-message"></span>
                </div>

                <div class="form-options">
                    <label class="remember-checkbox">
                        <input asp-for="RememberMe" type="checkbox" />
                        <span>Remember me</span>
                    </label>
                    <a asp-controller="Login" asp-action="ForgotPassword" class="forgot-link">Forgot Password?</a>
                </div>

                <input type="hidden" asp-for="ReturnUrl" />

                <button type="submit" class="login-btn">
                    <span>Sign In</span>
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"></path>
                        <polyline points="10 17 15 12 10 7"></polyline>
                        <line x1="15" y1="12" x2="3" y2="12"></line>
                    </svg>
                </button>

                <div class="divider">
                    <span>or</span>
                </div>

                <div class="register-prompt">
                    <p>Don't have an account?</p>
                    <a asp-controller="RegisterUser" asp-action="Index" class="register-link">Create Account</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}