@model WebApplication1.Models.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
}

<link href="~/css/forgotpassword.css" rel="stylesheet" />

<div class="forgot-password-page">
    <div class="forgot-password-container">
        <div class="forgot-password-header">
            <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="header-icon">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
            </svg>
            <h1>Forgot Password?</h1>
            <p>No worries! Enter your email address and we'll help you reset your password.</p>
        </div>

        <div class="forgot-password-card">
            <form asp-action="ForgotPassword" method="post" class="forgot-password-form">

                <div asp-validation-summary="ModelOnly" class="error-summary"></div>

                <div class="form-group">
                    <label asp-for="Email"></label>
                    <input asp-for="Email" class="form-control" placeholder="Enter your email address" autocomplete="email" />
                    <span asp-validation-for="Email" class="error-message"></span>
                    <small class="help-text">We'll send password reset instructions to this email</small>
                </div>

                <button type="submit" class="reset-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                        <polyline points="22,6 12,13 2,6"></polyline>
                    </svg>
                    <span>Send Reset Link</span>
                </button>

                <div class="back-to-login">
                    <a asp-controller="Login" asp-action="Index">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="m12 19-7-7 7-7"></path>
                            <path d="M19 12H5"></path>
                        </svg>
                        Back to Login
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}