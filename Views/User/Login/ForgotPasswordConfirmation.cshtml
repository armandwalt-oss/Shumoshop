@{
    ViewData["Title"] = "Password Reset Email Sent";
}

<link href="~/css/forgotpassword.css" rel="stylesheet" />

<div class="forgot-password-page">
    <div class="forgot-password-container">
        <div class="confirmation-card">
            <div class="success-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                    <polyline points="22 4 12 14.01 9 11.01"></polyline>
                </svg>
            </div>

            <h1>Check Your Email</h1>
            <p class="confirmation-text">
                If an account exists with the email you provided, you will receive password reset instructions shortly.
            </p>

            <div class="confirmation-details">
                <h3>What to do next:</h3>
                <ul>
                    <li>Check your email inbox (and spam folder)</li>
                    <li>Click the password reset link in the email</li>
                    <li>Follow the instructions to create a new password</li>
                </ul>
            </div>

            <div class="confirmation-help">
                <p>Didn't receive the email?</p>
                <a asp-action="ForgotPassword" class="resend-link">Resend Email</a>
            </div>

            <div class="back-to-login">
                <a asp-controller="Login" asp-action="Index" class="login-link-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="m12 19-7-7 7-7"></path>
                        <path d="M19 12H5"></path>
                    </svg>
                    Return to Login
                </a>
            </div>
        </div>
    </div>
</div>